<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:av="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="av" x:Class="LAC3.MainWindow"
        Title="LAC3" 
        Height="450" 
        Width="800"
        MinWidth="800" 
        MinHeight="450">
    <Grid ClipToBounds="True">
        <Grid x:Name="LayoutRoot" ClipToBounds="True">
            <!--Main Panel-->

            <Grid 
          x:Name="MainPanel"
          RenderOptions.BitmapScalingMode="NearestNeighbor"
          Visibility="Visible">
                <Grid.Background>
                    <ImageBrush ImageSource="/Assets/PMBG.png"/>
                </Grid.Background>
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>

                <Button Width="75" Height="75"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                BorderThickness="0"
                Click="ToKlikerPanel"
                Cursor="Hand"
                Padding="1"
                RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Button.Background>
                        <ImageBrush 
                        ImageSource="/Assets/PRPageArrow.png" 
                        Opacity="0.75"/>
                    </Button.Background>
                    <Button.Clip>
                        <EllipseGeometry 
                        Center="37.5,37.5" 
                        RadiusX="37.5" 
                        RadiusY="37.5"/>
                    </Button.Clip>
                </Button>

                <Button 
                Width="75" 
                Height="75"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                BorderThickness="0"
                Click="ToLogPanel"
                Cursor="Hand"
                Padding="1"
                RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Button.Background>
                        <ImageBrush 
                        ImageSource="/Assets/PLPageArrow.png" 
                        Opacity="0.75"/>
                    </Button.Background>
                    <Button.Clip>
                        <EllipseGeometry 
                        Center="37.5,37.5" 
                        RadiusX="37.5" 
                        RadiusY="37.5"/>
                    </Button.Clip>
                </Button>
                <Label 
                    Content="LAC3 0.0.7" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Height="27" 
                    Width="75" FontFamily="Consolas" FontWeight="Bold" Foreground="White"/>

                <Border 
                    Margin="115,10,0,0" 
                    Width="100" 
                    Height="25" 
                    Background="White" 
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left" 
                    Opacity="0.75" 
                    CornerRadius="8,8,8,8"/>
                <Border 
                    Margin="10,10,0,0" 
                    Width="100" 
                    Height="50" 
                    Background="White" 
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left" 
                    Opacity="0.75" 
                    CornerRadius="8,8,8,8"/>
                <Button 
                    Content="Flip" 
                    Click="CoinFlip"
                    HorizontalAlignment="Left" 
                    Margin="10,10,0,0" 
                    VerticalAlignment="Top" 
                    VerticalContentAlignment="Center" 
                    HorizontalContentAlignment="Center" 
                    Width="100" 
                    Height="50" 
                    FontFamily="Consolas" 
                    FontSize="16" 
                    FontWeight="Bold">
                    <Button.Foreground>
                        <SolidColorBrush 
                            Color="Black" 
                            Opacity="0.745"/>
                    </Button.Foreground>
                    <Button.Background>
                        <SolidColorBrush 
                            Color="Black" 
                            Opacity="0"/>
                    </Button.Background>
                </Button>
                <Label 
                    x:Name="CoinLabel"
                    Content="..." 
                    HorizontalAlignment="Left" 
                    HorizontalContentAlignment="Center" 
                    Margin="115,8,0,0" 
                    VerticalAlignment="Top" 
                    VerticalContentAlignment="Center" 
                    Height="27" 
                    Width="100" FontFamily="Consolas" FontWeight="Bold" FontSize="16">
                    <Label.Background>
                        <SolidColorBrush 
                            Opacity="0" 
                            Color="Black"/>
                    </Label.Background>
                </Label>

            </Grid>

            <!-- Settings Panel -->

            <Grid 
              x:Name="SettingsPanel"
              RenderOptions.BitmapScalingMode="NearestNeighbor"
              Visibility="Collapsed">
                <Grid.Background>
                    <ImageBrush 
                    ImageSource="/Assets/PSBG.png"/>
                </Grid.Background>
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>

                <Button 
                    Width="75" 
                    Height="75"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    BorderThickness="0"
                    Click="ToLogPanelY"
                    RenderOptions.BitmapScalingMode="NearestNeighbor" 
                    Cursor="Hand">
                    <Button.Background>
                        <ImageBrush 
                            ImageSource="/Assets/PDPageArrow.png" 
                            Opacity="0.75"/>
                    </Button.Background>
                    <Button.Clip>
                        <EllipseGeometry 
                            Center="37.5,37.5" 
                            RadiusX="37.5" 
                            RadiusY="37.5"/>
                    </Button.Clip>
                </Button>

                <Border
                    Margin="0,10,60,0" 
                    Background="White" 
                    Opacity="0.75" 
                    CornerRadius="8,8,8,8" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Width="196" 
                    Height="25" >
                    <Label 
                        Content="Performance Mode Time" 
                        FontSize="16" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Top" 
                        Height="30" 
                        Width="196" 
                        FontFamily="Consolas" 
                        FontWeight="Bold" 
                        Background="{x:Null}" 
                        Margin="0,-3,0,0" 
                        Foreground="Black"/>
                </Border>

                <Border
                    Margin="60,10,0,0" 
                    Background="White" 
                    Opacity="0.75" 
                    CornerRadius="8,8,8,8" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Height="25" 
                    Width="152" >
                    <Label 
                        Content="Performance mode" 
                        FontSize="16" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Top" 
                        Height="32" 
                        Width="161" 
                        Background="{x:Null}" 
                        FontFamily="Consolas" 
                        FontWeight="Bold" 
                        Margin="0,-2,0,0"/>
                </Border>

                <Border
                    Margin="60,47,0,0" 
                    Background="White" 
                    Opacity="0.75" 
                    CornerRadius="8,8,8,8" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Width="318" 
                    Height="25" >
                    <Label 
                        Content="Burst Mode Ignores Performance Mode" 
                        FontSize="16" 
                        HorizontalAlignment="Left" 
                        VerticalAlignment="Top" 
                        Height="33" 
                        Width="321" 
                        FontFamily="Consolas" 
                        FontWeight="Bold" 
                        Background="{x:Null}" 
                        Margin="0,-3,0,0"/>
                </Border>

                <Border 
                    Background="White" 
                    Width="50" 
                    Height="25" 
                    CornerRadius="8,8,8,8" 
                    Opacity="0.75" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Margin="10,10,0,0">
                    <Border 
                        x:Name="PerfCheck"
                        Margin="0,0,0,0" 
                        Visibility="Visible" 
                        Background="Black" 
                        Width="45" 
                        Height="19" 
                        CornerRadius="8,8,8,8" 
                        Opacity="0.75"/>
                </Border>

                <CheckBox 
                    x:Name="PerfCB"
                    Cursor="Hand"
                    Opacity="0"
                    IsChecked="True"
                    Checked="PerformanceMode"
                    Unchecked="PerformanceMode" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Margin="10,10,0,0" 
                    Height="25" 
                    Width="50"/>


                <Border 
                    Background="White" 
                    Width="50" 
                    Height="25" 
                    CornerRadius="8,8,8,8" 
                    Opacity="0.75" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Margin="10,47,0,0">
                    <Border 
                        x:Name="BIPMCheck"
                        Margin="2,3,2,3" 
                        Visibility="Visible" 
                        Background="Black" 
                        Width="45" 
                        Height="19" 
                        CornerRadius="8,8,8,8" 
                        Opacity="0.75"/>
                </Border>
                <CheckBox 
                     x:Name="BIPMCB"
                    Cursor="Hand"
                    Opacity="0"
                    IsChecked="True"
                    Checked="BurstIgnorePerfMode"
                    Unchecked="BurstIgnorePerfMode" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Top" 
                    Margin="10,47,0,0" 
                    Height="25" 
                    Width="50"/>

                <Border 
                    Margin="0,10,10,0" 
                    Width="50" 
                    Height="25" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Background="White" 
                    CornerRadius="8,8,8,8" 
                    Opacity="0.75">
                    <TextBox 
                        x:Name="PMT"
                        HorizontalAlignment="Center" 
                        TextWrapping="Wrap" 
                        Text="15" 
                        LostFocus="PMT_LostFocus"
                        KeyDown="PMT_KeyDown"
                        VerticalAlignment="Center" 
                        Width="50" 
                        Height="21" 
                        FontFamily="Consolas" 
                        FontWeight="Bold"
                        FontSize="16" 
                        TextAlignment="Center" 
                        Background="{x:Null}" 
                        BorderBrush="{x:Null}" 
                        Cursor="IBeam"/>
                </Border>

                <Border 
                    Margin="10,0,0,10" 
                    Opacity="0.75" 
                    Width="150" 
                    Height="50" 
                    HorizontalAlignment="Left" 
                    VerticalAlignment="Bottom" 
                    CornerRadius="8,8,8,8" 
                    Background="White" Cursor="Hand">
                    <Button 
                        Click="ResetSettings"
                        Content="Reset Settings" 
                        FontFamily="Consolas" 
                        FontWeight="Bold" 
                        FontSize="16" 
                        Cursor="Hand" 
                        Width="150" 
                        Height="50" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                        <Button.Background>
                            <SolidColorBrush Color="Black" Opacity="0"/>
                        </Button.Background>
                    </Button>
                </Border>

                <Border 
                    Margin="0,0,10,10" 
                    Opacity="0.75" 
                    Width="150" 
                    Height="50" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    CornerRadius="8,8,8,8" 
                    Background="White" Cursor="Hand">
                    <Button 
                        Click="LoadSettingsbtn"
                        Content="Load State" 
                        FontFamily="Consolas" 
                        FontWeight="Bold" 
                        FontSize="16" 
                        Cursor="Hand" 
                        Width="150" 
                        Height="50" 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                        <Button.Background>
                            <SolidColorBrush Color="Black" Opacity="0"/>
                        </Button.Background>
                    </Button>
                </Border>

                <Border 
                    Margin="0,0,165,10" 
                    Opacity="0.75" 
                    Width="150" 
                    Height="50" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Bottom" 
                    CornerRadius="8" 
                    Background="White"
                    Cursor="Hand">
                    <Button
                        Click="SaveSettingsbtn"
                        Content="Save State"
                        FontFamily="Consolas"
                        FontWeight="Bold"
                        FontSize="16"
                        Cursor="Hand"
                        Height="50"
                        Width="150"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                        <Button.Background>
                            <SolidColorBrush Color="Black" Opacity="0"/>
                        </Button.Background>
                    </Button>
                </Border>

            </Grid>

            <!-- Kliker Panel -->

            <Grid 
                  x:Name="KlikerPanel"
                  RenderOptions.BitmapScalingMode="NearestNeighbor"
                  Visibility="Collapsed">
                <Grid.Background>
                    <ImageBrush ImageSource="/Assets/PKBG.png"/>
                </Grid.Background>
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>

                <Button 
                    Width="75" 
                    Height="75"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    BorderThickness="0"
                    Click="ToMainPanel"
                    Cursor="Hand"
                    RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Button.Background>
                        <ImageBrush 
                            ImageSource="/Assets/PLPageArrow.png" 
                            Opacity="0.75"/>
                    </Button.Background>
                    <Button.Clip>
                        <EllipseGeometry 
                            Center="37.5,37.5" 
                            RadiusX="37.5" 
                            RadiusY="37.5"/>
                    </Button.Clip>
                </Button>
                <Border 
                    Margin="0,55,95,0" 
                    Background="Black" 
                    CornerRadius="8,8,8,8" 
                    VerticalAlignment="Top" 
                    Height="25" 
                    HorizontalAlignment="Right" 
                    RenderTransformOrigin="0.5,0.5" 
                    Width="150">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="-1"/>
                            <SkewTransform/>
                            <RotateTransform/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </Border.RenderTransform>
                </Border>

                <Label
                    Content="+"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center" 
                    FontFamily="Consolas" 
                    FontWeight="Bold" 
                    FontSize="36" 
                    Margin="0,40,21,0" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Right" 
                    Width="35"/>

                <Label
                    Content="-"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center" 
                    FontFamily="Consolas" 
                    FontWeight="Bold" 
                    FontSize="36" 
                    Margin="0,40,55,0" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Right" 
                    Width="35"/>

                <Label
                    Content="-"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center" 
                    FontFamily="Consolas" 
                    FontWeight="Bold" 
                    FontSize="36" 
                    Margin="0,40,290,0" 
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Right" 
                    Width="35"/>
                <Border 

                    Background="#FF2C4231"
                    Margin="75,45,15,10" 
                    CornerRadius="8" 
                    Opacity="0.75">

                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel 
                            Grid.Row="0" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Margin="5">
                            <Button 
                                x:Name="ClearAllProfileButton"
                                Width="35" 
                                Height="35"
                                Click="ClearAllProfiles"
                                Background="Red"
                                Cursor="Hand"
                                ToolTip="Clear all profiles"/>
                            <Label 
                                Target="{Binding ElementName=ProfileNameTextBox}" 
                                VerticalAlignment="Center"
                                Foreground="White"
                                Content="Name:" FontFamily="Consolas" FontWeight="Bold" Width="45" Height="25"/>

                            <TextBox
                                x:Name="ProfileNameTextBox2"
                                Width="150"
                                Height="25"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                TextChanged="ProfileNameTextBox_TextChanged" 
                                BorderBrush="{x:Null}" 
                                VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Center" 
                                Foreground="White">
                                <TextBox.Background>
                                    <SolidColorBrush Color="White" Opacity="0"/>
                                </TextBox.Background>
                            </TextBox>

                            <Button 
                                x:Name="DeleteProfileButton"
                                Width="35" 
                                Height="35"
                                Click="DeleteProfile"
                                Background="#FFFF8080"
                                Cursor="Hand"
                                ToolTip="Delete a profile">
                            </Button>

                            <Button 
                                x:Name="AddProfileButton"
                                Width="35" 
                                Height="35"
                                Click="AddProfile"
                                Background="#FF80FF80"
                                Cursor="Hand"
                                ToolTip="Add a new profile">
                            </Button>

                        </StackPanel>

                        <ScrollViewer 
                            Grid.Row="1" 
                            VerticalScrollBarVisibility="Auto" 
                            Margin="5">
                            <StackPanel 
                                x:Name="ProfilesPanel" 
                                Orientation="Vertical">
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>






            </Grid>

            <!-- Log Panel -->

            <Grid 
              x:Name="LogPanel"
              RenderOptions.BitmapScalingMode="NearestNeighbor"
              Visibility="Collapsed">
                <Grid.Background>
                    <ImageBrush ImageSource="/Assets/PLBG.png"/>
                </Grid.Background>
                <Grid.RenderTransform>
                    <TranslateTransform/>
                </Grid.RenderTransform>

                <Button 
                Width="75" 
                Height="75"
                HorizontalAlignment="Right"
                BorderThickness="0,0,0,0"
                Click="ToMainPanel" 
                Cursor="Hand" 
                Padding="1,1,1,1"
                RenderOptions.BitmapScalingMode="NearestNeighbor" 
                Margin="0,0,0,10" 
                VerticalAlignment="Bottom">
                    <Button.Background>
                        <ImageBrush 
                        ImageSource="/Assets/PRPageArrow.png" 
                        Opacity="0.75"/>
                    </Button.Background>
                    <Button.Clip>
                        <EllipseGeometry 
                        Center="37.5,37.5" 
                        RadiusX="37.5" 
                        RadiusY="37.5"/>
                    </Button.Clip>
                </Button>

                <Button 
                HorizontalAlignment="Left" 
                Margin="10,10,0,0" 
                VerticalAlignment="Top" 
                Height="35" 
                Width="35" 
                Click="ToSettingsPanel"
                BorderThickness="0,0,0,0"
                Cursor="Hand" 
                Padding="1,1,1,1"
                RenderOptions.BitmapScalingMode="NearestNeighbor">
                    <Button.Background>
                        <ImageBrush ImageSource="/Assets/PSettings.png"/>
                    </Button.Background>
                    <Button.Clip>
                        <EllipseGeometry 
                        Center="17.5,17.5" 
                        RadiusX="17.5" 
                        RadiusY="17.5"/>
                    </Button.Clip>
                </Button>

                <Border 
                    BorderBrush="#FFB1A887" 
                    BorderThickness="5,5,5,5" 
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Margin="10,50,80,10"
                    ClipToBounds="True" 
                    CornerRadius="8,8,8,8" 
                    Opacity="0.75">
                    <Border
                        x:Name="InnerBorder"
                        CornerRadius="8"
                        Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ClipToBounds="True">
                        <TextBox
                            Name="LogOutputTx"
                            VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto"
                            TextWrapping="Wrap"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            FontFamily="Consolas"
                            Background="Transparent"
                            BorderThickness="0"
                            TextChanged="LogOutput" 
                            FontSize="16"/>
                    </Border>
                </Border>
            </Grid>
        </Grid>

        <!-- Profile Panel -->

        <Grid 
              x:Name="ProfilePanel"
              RenderOptions.BitmapScalingMode="NearestNeighbor"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="#FFB9B9B9" Opacity="1"/>
            </Grid.Background>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RenderTransform>
                <TranslateTransform/>
            </Grid.RenderTransform>

            <Label 
                    x:Name="EditingLabel"
                    Content="Editing ..." 
                    Margin="0,80,0,0" 
                    VerticalAlignment="Top" 
                    FontSize="24" 
                    FontFamily="Consolas" 
                    FontWeight="Bold" 
                    Grid.ColumnSpan="2" 
                    HorizontalAlignment="Center" 
                    Width="250" 
                    Height="50"/>

            <Button 
                    Width="76" 
                    Height="75"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    BorderThickness="0"
                    Click="ToKlikerPanelY"
                    RenderOptions.BitmapScalingMode="NearestNeighbor" 
                    Cursor="Hand" Grid.ColumnSpan="2">
                <Button.Background>
                    <ImageBrush 
                        ImageSource="/Assets/PUPageArrow.png" 
                        Opacity="0.75"/>
                </Button.Background>
                <Button.Clip>
                    <EllipseGeometry 
                        Center="37.5,37.5" 
                        RadiusX="40" 
                        RadiusY="40"/>
                </Button.Clip>
            </Button>

            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,10,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,40,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,70,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,100,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,250,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,280,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,220,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,190,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,160,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>
            <Border 
                BorderBrush="Black" 
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Height="25" 
                Width="250" 
                Margin="0,130,10,0" 
                Background="#FF6F6F6F" 
                CornerRadius="8,8,8,8" 
                Opacity="0.75" 
                Grid.Column="1"/>

            <TextBox
                ToolTip="The name of this profile"
                TextWrapping="Wrap"
                Background="{x:Null}"
                Name="NProfileNameTextBox"
                PreviewTextInput="ProfileNameTextBox"
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center" 
                Height="25" 
                Margin="0,10,10,0" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Right" 
                Width="250" BorderBrush="{x:Null}" Grid.Column="1"/>
            <Button 
                Content="Save Changes" 
                Width="250" 
                Click="SaveProfileChanges" 
                Cursor="Hand" 
                FontFamily="Consolas" 
                FontWeight="Bold" 
                Height="51" 
                VerticalAlignment="Bottom" 
                Margin="275,0,275,10" 
                Grid.ColumnSpan="2">
                <Button.Background>
                    <SolidColorBrush Color="#FF7B7B7B" Opacity="0.75"/>
                </Button.Background>
            </Button>

            <TextBox 
                x:Name="Bind"
                ToolTip="The key to activate this profile"
                IsReadOnly="True"
                Text="(Click to bind)"
                VerticalAlignment="Top"
                Padding="5"
                PreviewMouseDown="SetMouseBinding"
                PreviewKeyDown="SetKeyBinding" 
                Height="25" 
                Margin="0,40,10,0" 
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center" 
                HorizontalAlignment="Right" 
                Width="250" 
                Background="{x:Null}" 
                BorderBrush="{x:Null}" 
                FontWeight="Bold" 
                FontFamily="Consolas" 
                Grid.Column="1"/>
            <TextBox 
                x:Name="BindClick"
                ToolTip="The key that should be automatically pressed"
                IsReadOnly="True"
                Text="(Click to bind)"
                VerticalAlignment="Top"
                Padding="5"
                PreviewMouseDown="SetMouseClickBinding"
                PreviewKeyDown="SetKeyPressBinding" 
                Height="25" 
                Margin="0,70,10,0" 
                HorizontalAlignment="Right" 
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center" 
                Width="250" 
                Background="{x:Null}" 
                BorderBrush="{x:Null}" 
                FontFamily="Consolas" 
                FontWeight="Bold" 
                Grid.Column="1"/>
            <TextBox 
                ToolTip="(Ms) Anti detection. The maximum amount of time to be randomised between Delay and MaxDelay. Set this to the same or less than Delay to disable this."
                TextWrapping="Wrap"
                Background="{x:Null}"
                Name="NMaxDelayTextBox"
                PreviewTextInput="MaxDelayTextBox" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Right" 
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center" 
                Height="25" 
                Width="250" 
                Margin="0,160,10,0" 
                BorderBrush="{x:Null}" 
                Grid.Column="1"/>
            <TextBox 
                ToolTip="(Ms) Time between each ActionKey press"
